# ===========================================================================
# Configuração da Multicloud AI Platform
# Copie para .env e preencha. SEM credenciais, a plataforma roda em MODO DEMO.
# ===========================================================================

# Modo demo: respostas sintéticas sem chamar os clouds (docker-compose up
# funciona ponta-a-ponta offline). Defina como "false" para usar modelos reais.
DEMO_MODE=true

# Limite de tokens de saída por chamada.
MAX_TOKENS=1024

# --- AWS Bedrock (Claude Haiku 4.5) ---------------------------------------
# Em produção/ECS, prefira a IAM role da task em vez de chaves estáticas.
AWS_DEFAULT_REGION=us-west-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Opcional: sobrescreve o inference profile padrão.
AWS_BEDROCK_MODEL_ID=us.anthropic.claude-haiku-4-5

# --- OCI Generative AI (Cohere Command R) ---------------------------------
# Requer ~/.oci/config montado no container e o compartment abaixo.
OCI_COMPARTMENT_ID=
OCI_REGION=us-chicago-1
OCI_MODEL_ID=cohere.command-r-08-2024

# --- GCP Vertex AI (Gemini 1.5 Flash) -------------------------------------
# Requer GOOGLE_APPLICATION_CREDENTIALS apontando para a service account.
GCP_PROJECT_ID=
GCP_LOCATION=us-central1
GCP_MODEL_ID=gemini-1.5-flash
